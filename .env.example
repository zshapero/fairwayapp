# GolfCourseAPI key (currently unused — local DB search is the fallback).
EXPO_PUBLIC_GOLF_COURSE_API_KEY=

# Sentry — crash reporting.
# Sign up at https://sentry.io (free tier), create a React Native project,
# copy the DSN here. In CI/EAS, add as a GitHub secret of the same name.
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — anonymous product analytics.
# Sign up at https://posthog.com (1M events/month free), create a project,
# copy the project API key here. The host defaults to the US instance;
# override if you're on EU.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Open-Meteo (weather) — no API key required. The service uses the free
# archive + forecast endpoints. Throttled to 1 request per 200ms in
# backfillRoundWeather to stay polite.
